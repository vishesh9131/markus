# Auth.js — required
AUTH_SECRET=generate-with: openssl rand -base64 32
AUTH_URL=http://localhost:4400

# Google OAuth (Drive-backed workspaces). Create at console.cloud.google.com:
#  - OAuth consent screen (External), add scope .../auth/drive.file
#  - Authorized redirect URI: http://localhost:4400/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Razorpay (premium = INR 9 / 2 months). Dashboard > API keys (test mode ok):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Premium price (paise) and duration. 900 paise = INR 9
PREMIUM_AMOUNT_PAISE=900
PREMIUM_MONTHS=2

# --- Split hosting (Netlify front + Render compiler) ---
# On the NETLIFY site only, set this to your Render URL so the browser sends
# compile requests there (Render has Python+LaTeX). Leave empty for single-host.
NEXT_PUBLIC_COMPILE_URL=
# On the RENDER compiler, optionally lock CORS to your Netlify origin:
# COMPILE_ALLOW_ORIGIN=https://markus-app.netlify.app
