# Auth.js — required
AUTH_SECRET=generate-with: openssl rand -base64 32
AUTH_URL=http://localhost:4400

# Google OAuth (Drive-backed workspaces). Create at console.cloud.google.com:
#  - OAuth consent screen (External), add scope .../auth/drive.file
#  - Authorized redirect URI: http://localhost:4400/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Razorpay (premium = INR 9 / 2 months). Dashboard > API keys.
#  - Test mode keys start with rzp_test_ ; live (production) keys with rzp_live_.
#  - Going live = activate the account (KYC) + generate Live keys + set them here.
#    No code change is needed; the same routes serve test and live.
#  - The browser receives the key id from /api/billing/order, so there is NO
#    NEXT_PUBLIC_RAZORPAY_KEY_ID to set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay webhook (recommended for production). In Dashboard > Settings >
# Webhooks add URL https://<site>/api/billing/webhook for event payment.captured,
# using this exact secret. Grants premium even if the buyer closes the tab.
RAZORPAY_WEBHOOK_SECRET=

# Premium price (paise) and duration. 900 paise = INR 9
PREMIUM_AMOUNT_PAISE=900
PREMIUM_MONTHS=2

# --- Split hosting (Netlify front + Render compiler) ---
# On the NETLIFY site only, set this to your Render URL so the browser sends
# compile requests there (Render has Python+LaTeX). Leave empty for single-host.
NEXT_PUBLIC_COMPILE_URL=
# On the RENDER compiler, optionally lock CORS to your Netlify origin:
# COMPILE_ALLOW_ORIGIN=https://markus-app.netlify.app

# Promo code that unlocks premium without payment.
# IMPORTANT: in production set this to a PRIVATE value. The default fallback
# (markus@Vishesh) is committed in this repo, so anyone could redeem it for free.
PROMO_CODE=markus@Vishesh
# PROMO_MONTHS=2
